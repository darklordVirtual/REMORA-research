{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aromer-cognitive-seed-v0.2",
  "title": "AROMER Cognitive Seed Entry",
  "description": "Schema for cognitive-layer seeds. These seeds do not modify tool-risk priors — they encode thinking principles, epistemic foundations, error models, causal reasoning, planning heuristics, memory architecture, self-model, learning laws, transfer rules and evaluation gates.",
  "note": "Preseed != truth. Preseed = hypothesis with provenance. Seed packs skal gi AROMER et bedre startkart, ikke gjøre den skråsikker.",
  "type": "object",
  "required": ["id", "type", "source", "version", "weight", "confidence", "description", "payload"],
  "additionalProperties": false,
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9_-]+$"},
    "type": {
      "type": "string",
      "enum": [
        "cognitive_primitive",
        "epistemic_foundation",
        "error_taxonomy",
        "causal_reasoning",
        "planning",
        "memory_architecture",
        "self_model",
        "learning_law",
        "transfer_rule",
        "domain_capsule",
        "eval_gate"
      ]
    },
    "source": {"type": "string"},
    "version": {"type": "string"},
    "weight": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "decay_rate": {"type": "number", "minimum": 0.0},
    "tags": {"type": "array", "items": {"type": "string"}},
    "description": {"type": "string"},
    "payload": {"type": "object"}
  },
  "cognitive_layer_map": {
    "1_truth_uncertainty":    "cognitive_primitive + epistemic_foundation",
    "2_error_counterexample": "error_taxonomy",
    "3_causal_reasoning":     "causal_reasoning",
    "4_planning":             "planning",
    "5_memory":               "memory_architecture",
    "6_self_model":           "self_model",
    "7_learning_laws":        "learning_law",
    "8_transfer_abstraction": "transfer_rule",
    "9_domain_capsules":      "domain_capsule",
    "10_eval_gates":          "eval_gate"
  }
}
